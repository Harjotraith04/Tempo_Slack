# ─── Slack ───────────────────────────────────────────────────────────────────
# From your Slack app (https://api.slack.com/apps → your app)
SLACK_BOT_TOKEN=xoxb-...
SLACK_SIGNING_SECRET=...
SLACK_CLIENT_ID=...
SLACK_CLIENT_SECRET=...
# Socket Mode app-level token (xapp-...), used for local dev without a public URL
SLACK_APP_TOKEN=xapp-...

# The per-user USER token Tempo acts with (no action_token needed for RTS).
# In production this is obtained per-user via OAuth; for local dev you can paste
# a single user token here to drive the demo as "Sam".
SLACK_USER_TOKEN=xoxp-...

# Your own Slack user id (U...). Only used by `npm run verify:rts`, so the
# subject-derived fields (mentionsMe) mean something against a real workspace —
# the built-in fixture id exists only in the mock. Find it in your Slack profile.
# SLACK_SUBJECT_USER_ID=U0123ABC

# ─── AI (OpenAI) ─────────────────────────────────────────────────────────────
# ONE key powers BOTH the reasoning modules and read-aloud (TTS) below. Setting
# it flips both seams to live — that is intended.
OPENAI_API_KEY=sk-...
# Use a gpt-4.1-class model. NOT gpt-5.* and NOT an o-series id.
# Why it matters: the adapter sends `temperature` on every call, and the AI SDK
# SILENTLY STRIPS temperature for models it treats as reasoning models (id
# starting with "o" or "gpt-5"). The call still succeeds — so a wrong id here is
# an INVISIBLE regression, not a loud failure, and no test catches it (the mock
# adapter is only selected when OPENAI_API_KEY is ABSENT).
# Check it in one command: npm run verify:ai
TEMPO_MODEL=gpt-4.1-mini
# live = call OpenAI; mock = deterministic canned reasoning (runs with no key).
# Auto-detects to "live" when OPENAI_API_KEY is set, else "mock".
TEMPO_AI=mock

# ─── Read-aloud (TTS) ────────────────────────────────────────────────────────
# Uses the same OPENAI_API_KEY above (OpenAI tts-1) to synthesize the read-aloud
# speech script into real audio when a user turns on the "read aloud" pref.
# With NO key the mock returns a valid but SILENT wav — fine for tests, useless
# on camera, so set the key before recording if you demo read-aloud.
# TEMPO_TTS_VOICE=alloy
# live = call OpenAI's speech endpoint; mock = silent WAV. Auto-detects to
# "live" when OPENAI_API_KEY is set.
TEMPO_TTS=mock

# ─── Deployment ──────────────────────────────────────────────────────────────
# The public origin of this deployment, no trailing slash. The Slack OAuth
# redirect_uri is built from it (api/oauth/start.ts + callback.ts) — unset, the
# redirect_uri degrades to a relative path and Slack rejects the install with no
# useful error. REQUIRED on Vercel: assertVercelRuntime() throws without it.
# PUBLIC_URL=https://your-app.vercel.app

# The web companion's own origin (second Vercel project). Only read by
# `npm run manifest:urls`, which falls back to PUBLIC_URL when unset.
# WEB_PUBLIC_URL=https://your-web.vercel.app

# Shared secret for the Vercel cron endpoint (/api/cron/morning-digest).
# If set, the route requires `Authorization: Bearer <secret>`. If UNSET, the
# endpoint is open to anyone — set it in production. Vercel Cron injects this
# header automatically when the project has a CRON_SECRET env var.
#   openssl rand -hex 32
# CRON_SECRET=

# ─── Runtime ─────────────────────────────────────────────────────────────────
# socket = local dev via Socket Mode; http = HTTP receiver (Vercel/prod)
# On Vercel (VERCEL=1 is set automatically) the receiver defaults to http —
# there is no socket mode on serverless, and the http posture also arms the
# secrets-hardening assertion in production.
TEMPO_RECEIVER=socket
PORT=3000

# Use the seeded mock RTS adapter instead of live assistant.search.context.
# Set to "live" once RTS access is confirmed for your app.
TEMPO_RTS=mock

# Encryption key for stored user tokens (32+ chars). Generate a random one.
TEMPO_ENCRYPTION_KEY=change-me-to-a-long-random-string

# ─── Native surfaces (v2.0) ──────────────────────────────────────────────────
# Feature flags for the native surfaces. Default ON; set to "off" to hide the
# App Home buttons / skip the cron canvas refresh. The mock/live seam is still
# governed by TEMPO_SLACK_ACTIONS (below) — a surface can be on but fully mocked.
# TEMPO_CANVAS=on          # Tempo Canvas (canvases.create/edit)
# TEMPO_LISTS=on           # Slack Lists sync of the Commitment Ledger
# TEMPO_PROACTIVE=on       # (v3.4) opt-in overload heads-up + batched FYIs in the morning digest (default off)
# TEMPO_TEAM=on            # (v3.6) opt-in aggregated + anonymized team view (default off)
# TEMPO_TEAM_MEMBERS=U0AAA,U0BBB,U0CCC   # explicit opt-in roster (nobody aggregated unless listed)
# TEMPO_TEAM_MIN=3         # k-anonymity floor: redact the whole view below this many opted-in members
# TEMPO_ATTENTION_OS=on    # (v4.0) ground across Slack + mock email/calendar as one working memory (default off)

# Slack write-actions (focus DND/status/digest + canvas/list/reminders/bookmark).
# mock = deterministic, zero I/O (default); live = call the real Slack Web API.
# Independent from TEMPO_RTS so live RTS never silently flips your DND/canvas.
TEMPO_SLACK_ACTIONS=mock

# ─── Outbound MCP (Focus Guardian: calendar block + task) ────────────────────
# mock = deterministic, zero I/O (default); live = connect to real MCP servers
# over Streamable HTTP. Each client goes live only when TEMPO_MCP=live AND its
# own server URL is set — a partial config leaves the other on mock.
TEMPO_MCP=mock
# Calendar MCP server (e.g. a Google Calendar MCP). Optional bearer token.
# TEMPO_MCP_CALENDAR_URL=https://your-calendar-mcp.example.com/mcp
# TEMPO_MCP_CALENDAR_TOKEN=
# TEMPO_MCP_CALENDAR_TOOL=create_event
# TEMPO_MCP_CALENDAR_PROVIDER=google-calendar
# Tasks MCP server (Notion / Linear / GitHub, whichever you point it at).
# TEMPO_MCP_TASKS_URL=https://your-tasks-mcp.example.com/mcp
# TEMPO_MCP_TASKS_TOKEN=
# TEMPO_MCP_TASKS_TOOL=create_task
# TEMPO_MCP_TASKS_PROVIDER=notion

# Inbound MCP server (v3.0) — expose Tempo AS an MCP server so external agents
# (Agentforce / Claude / Cursor / ChatGPT) can call tempo_triage/commitments/
# decode/focus at /api/mcp/server. Off by default; set a bearer token to gate it.
# TEMPO_MCP_SERVER=on
# Default-deny: callers present a signed per-user agent token (mintAgentToken).
# The shared token below is accepted ONLY if TEMPO_MCP_SERVER_USER is also set
# (maps that one shared secret to that one configured user — no ambient authority).
# TEMPO_MCP_SERVER_TOKEN=a-long-random-secret
# TEMPO_MCP_SERVER_USER=U0123ABC

# ─── Persistence (Neon Postgres) ─────────────────────────────────────────────
# file = JSON files under TEMPO_STORE_DIR (default; the zero-credential demo/
# tests). postgres = Neon behind the same repository interfaces (durable on
# Vercel's read-only FS). File stays the default; postgres also needs a
# DATABASE_URL to engage. Auto-detects to "postgres" when DATABASE_URL is set.
# NOTE: on Vercel the file store is rejected at startup (read-only filesystem)
# — set DATABASE_URL there so the store auto-detects to postgres.
TEMPO_STORE=file
# DATABASE_URL=postgres://user:pass@ep-xxx.neon.tech/neondb?sslmode=require
# Verify a live database (non-destructive round-trip): npm run verify:postgres
