{
  "display_information": {
    "name": "Tempo",
    "description": "Your working memory for Slack \u2014 triages the firehose, remembers your commitments, decodes tone, protects your focus.",
    "background_color": "#1f2330",
    "long_description": "Tempo is an executive-function co-pilot: assistive technology for the way humans actually work in Slack. It triages everything since you were last active into what truly needs you, tracks the promises you made and were made to you, decodes the implicit tone and subtext of messages, and protects your attention. Grounded live in the Slack Real-Time Search API; nothing it reads is ever stored. Built for the ~15-20% of workers who are neurodivergent, for non-native speakers, and for everyone drowning in the firehose."
  },
  "features": {
    "bot_user": {
      "display_name": "Tempo",
      "always_online": true
    },
    "app_home": {
      "home_tab_enabled": true,
      "messages_tab_enabled": true,
      "messages_tab_read_only_enabled": false
    },
    "agent_view": {
      "agent_description": "I triage your Slack, remember your commitments, decode tone, and protect your focus.",
      "suggested_prompts": [
        {
          "title": "What needs me today?",
          "message": "What needs me today?"
        },
        {
          "title": "What did I promise?",
          "message": "Show my open commitments."
        },
        {
          "title": "Catch me up",
          "message": "Catch me up on what I missed while I was away."
        }
      ]
    },
    "slash_commands": [
      {
        "command": "/tempo",
        "description": "Triage, commitments, decode tone, focus, or catch-up",
        "usage_hint": "[triage | commitments | catchup | focus | help]",
        "should_escape": false,
        "url": "https://tempo-slack.vercel.app/api/slack/events"
      }
    ]
  },
  "functions": {
    "summarize_missed": {
      "title": "Summarize what I missed",
      "description": "Tempo writes a calm, plain-language brief of what changed while you were away.",
      "input_parameters": {
        "user": {
          "type": "slack#/types/user_id",
          "title": "For user",
          "description": "Whose Slack to summarize",
          "is_required": true
        }
      },
      "output_parameters": {
        "summary": {
          "type": "string",
          "title": "Summary",
          "description": "The re-entry brief",
          "is_required": true
        }
      }
    },
    "draft_reply": {
      "title": "Draft a reply",
      "description": "Tempo drafts a warm, clear reply to a message. It never sends \u2014 you review and send yourself.",
      "input_parameters": {
        "user": {
          "type": "slack#/types/user_id",
          "title": "For user",
          "description": "Whose voice to draft in",
          "is_required": true
        },
        "message": {
          "type": "string",
          "title": "Message to reply to",
          "description": "The text you want to respond to",
          "is_required": true
        }
      },
      "output_parameters": {
        "draft": {
          "type": "string",
          "title": "Draft reply",
          "description": "The suggested reply text",
          "is_required": true
        }
      }
    },
    "block_focus": {
      "title": "Block focus time",
      "description": "Tempo protects a deep-work block: real calendar time plus Do-Not-Disturb.",
      "input_parameters": {
        "user": {
          "type": "slack#/types/user_id",
          "title": "For user",
          "description": "Whose focus to protect",
          "is_required": true
        },
        "minutes": {
          "type": "number",
          "title": "Minutes",
          "description": "How long to protect (default 90)",
          "is_required": false
        }
      },
      "output_parameters": {
        "summary": {
          "type": "string",
          "title": "Summary",
          "description": "What was blocked",
          "is_required": true
        }
      }
    },
    "add_commitment": {
      "title": "Add a commitment",
      "description": "Tempo tracks a promise and sets a native reminder so it doesn't slip.",
      "input_parameters": {
        "user": {
          "type": "slack#/types/user_id",
          "title": "For user",
          "description": "Whose commitment to track",
          "is_required": true
        },
        "what": {
          "type": "string",
          "title": "What",
          "description": "The deliverable (e.g. 'Send the Atlas spec')",
          "is_required": true
        },
        "counterparty": {
          "type": "string",
          "title": "To whom",
          "description": "Who it's for",
          "is_required": false
        }
      },
      "output_parameters": {
        "confirmation": {
          "type": "string",
          "title": "Confirmation",
          "description": "What Tempo tracked",
          "is_required": true
        }
      }
    }
  },
  "oauth_config": {
    "redirect_urls": [
      "https://tempo-slack.vercel.app/api/oauth/callback"
    ],
    "scopes": {
      "user": [
        "search:read.public",
        "search:read.private",
        "search:read.im",
        "search:read.mpim",
        "search:read.files",
        "search:read.users",
        "dnd:write",
        "users.profile:write",
        "canvases:write",
        "lists:write",
        "reminders:write"
      ],
      "bot": [
        "assistant:write",
        "chat:write",
        "im:write",
        "im:history",
        "commands",
        "app_mentions:read",
        "files:write",
        "bookmarks:write",
        "users:read",
        "channels:manage",
        "channels:read",
        "chat:write.customize",
        "channels:history"
      ]
    }
  },
  "settings": {
    "event_subscriptions": {
      "request_url": "https://tempo-slack.vercel.app/api/slack/events",
      "bot_events": [
        "message.im",
        "app_mention",
        "app_home_opened",
        "function_executed",
        "assistant_thread_started",
        "assistant_thread_context_changed"
      ]
    },
    "interactivity": {
      "is_enabled": true,
      "request_url": "https://tempo-slack.vercel.app/api/slack/events"
    },
    "socket_mode_enabled": false,
    "org_deploy_enabled": true,
    "token_rotation_enabled": false,
    "function_runtime": "remote"
  }
}
